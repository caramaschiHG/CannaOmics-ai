# ──────────────────────────────────────────────────────────────────────
# CannaOmics AI – Environment Variables
# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env and adjust values for your local setup.
#
#   cp .env.example .env
#
# ──────────────────────────────────────────────────────────────────────

# Base directory for raw / interim / processed data
CANNAOMICS_DATA_DIR=./data

# Directory for pipeline outputs and reports
CANNAOMICS_RESULTS_DIR=./results

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
CANNAOMICS_LOG_LEVEL=INFO
